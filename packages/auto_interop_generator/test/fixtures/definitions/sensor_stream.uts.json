      "documentation": "Streams accelerometer sensor data.",
      "nativeBody": {
        "swift_onListen": "#if os(iOS)\nguard motionManager.isAccelerometerAvailable else {\n    events(FlutterError(code: \"UNAVAILABLE\", message: \"Accelerometer not available on this device\", details: nil))\n    return nil\n}\nlet rate = (args[\"samplingRate\"] as? Int) ?? 60\nmotionManager.accelerometerUpdateInterval = 1.0 / Double(rate)\nmotionManager.startAccelerometerUpdates(to: .main) { [weak self] data, error in\n    if let error = error {\n        self?.eventSink?(FlutterError(code: \"SENSOR_ERROR\", message: error.localizedDescription, details: nil))\n        return\n    }\n    guard let data = data else { return }\n    let event: [String: Any] = [\n        \"x\": data.acceleration.x,\n        \"y\": data.acceleration.y,\n        \"z\": data.acceleration.z,\n        \"timestamp\": ISO8601DateFormatter().string(from: Date())\n    ]\n    self?.eventSink?(event)\n}\n#else\nevents(FlutterError(code: \"PLATFORM_UNSUPPORTED\", message: \"Accelerometer is not available on macOS\", details: nil))\n#endif",
        "swift_onCancel": "motionManager.stopAccelerometerUpdates()",
        "kotlin_onListen": "val rate = (args[\"samplingRate\"] as? Int) ?: 60\nval interval = 1000L / rate\n// Start sensor sampling at given rate",
