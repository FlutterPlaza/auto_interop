          "documentation": "Downloads a file from a URL.",
          "nativeBody": {
            "swift": "let url = args[\"url\"] as! String\nlet destination = args[\"destination\"] as? String\nlet handle = args[\"_handle\"] as! String\nlet instance = instances[handle] as! Session\nlet downloadRequest = instance.download(url)\ndownloadRequest.responseData { response in\n    switch response.result {\n    case .success(let data):\n        if let dest = destination {\n            try? data.write(to: URL(fileURLWithPath: dest))\n            DispatchQueue.main.async { result(dest) }\n        } else {\n            DispatchQueue.main.async { result(\"downloaded \\(data.count) bytes\") }\n        }\n    case .failure(let error):\n        DispatchQueue.main.async {\n            result(FlutterError(code: \"ALAMOFIRE_ERROR\", message: error.localizedDescription, details: nil))\n        }\n    }\n}"
          }
        },
