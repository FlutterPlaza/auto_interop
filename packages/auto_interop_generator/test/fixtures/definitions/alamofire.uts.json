          },
          "documentation": "Uploads data to a URL.",
          "nativeBody": {
            "swift": "let data = args[\"data\"] as! FlutterStandardTypedData\nlet url = args[\"url\"] as! String\nlet handle = args[\"_handle\"] as! String\nlet instance = instances[handle] as! Session\ninstance.upload(data.data, to: url).responseData { response in\n    switch response.result {\n    case .success:\n        DispatchQueue.main.async { result(\"uploaded \\(data.data.count) bytes\") }\n    case .failure(let error):\n        DispatchQueue.main.async {\n            result(FlutterError(code: \"ALAMOFIRE_ERROR\", message: error.localizedDescription, details: nil))\n        }\n    }\n}"
          }
        }
