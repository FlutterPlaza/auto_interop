          "documentation": "Adds a response handler.",
          "nativeBody": {
            "swift": "let handle = args[\"_handle\"] as! String\nlet instance = instances[handle] as! Alamofire.DataRequest\ninstance.responseData { response in\n    var dict: [String: Any] = [:]\n    if let data = response.data {\n        dict[\"data\"] = FlutterStandardTypedData(bytes: data)\n    }\n    dict[\"statusCode\"] = response.response?.statusCode ?? 0\n    var headerDict: [String: String] = [:]\n    if let allHeaders = response.response?.allHeaderFields {\n        for (key, value) in allHeaders {\n            headerDict[String(describing: key)] = String(describing: value)\n        }\n    }\n    dict[\"headers\"] = headerDict\n    DispatchQueue.main.async {\n        result(dict)\n    }\n}"
          }
        },
